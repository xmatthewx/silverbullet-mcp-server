{
  "name": "silverbullet-mcp-server",
  "version": "0.5.0",
  "description": "A standalone remote MCP server that exposes any hosted SilverBullet space to Claude over HTTP, with built-in OAuth 2.1 and collision-safe writes.",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "author": "Beta Brooklyn",
  "homepage": "https://github.com/xmatthewx/silverbullet-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/xmatthewx/silverbullet-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/xmatthewx/silverbullet-mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "silverbullet",
    "claude",
    "notes",
    "oauth"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
