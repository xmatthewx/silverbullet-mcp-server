# SilverBullet instance (the address Claude's MCP server will call)
SB_URL=https://notes.example.com

# Bearer token configured in SilverBullet (SB_AUTH_TOKEN on the SB side)
SB_TOKEN=replace-me-with-sb-auth-token

# Bearer token Claude clients must present to reach this MCP server
# Generate with: openssl rand -hex 32
MCP_TOKEN=replace-me-with-a-long-random-string

# Port the MCP server listens on (Fly maps this internally)
PORT=8080
