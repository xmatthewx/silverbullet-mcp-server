# --- SilverBullet upstream -----------------------------------------------

# Base URL of the SilverBullet instance (no trailing slash)
SB_URL=https://notes.example.com

# SB_AUTH_TOKEN configured on the SilverBullet side
SB_TOKEN=replace-me-with-sb-auth-token

# --- Inbound auth --------------------------------------------------------

# Static bearer token kept as a dev / curl bypass alongside OAuth.
# Generate with: openssl rand -hex 32
MCP_TOKEN=replace-me-with-a-long-random-string

# Public URL of *this* MCP server (used in OAuth metadata documents).
# In dev:  http://localhost:8080
# On Fly:  https://your-app.fly.dev  (or your custom domain)
PUBLIC_URL=http://localhost:8080

# OAuth client credentials. You'll paste these into Claude.ai's connector
# "Advanced settings" fields.
#   OAUTH_CLIENT_ID:     any opaque string; recommended: uuidgen
#   OAUTH_CLIENT_SECRET: openssl rand -hex 32
OAUTH_CLIENT_ID=replace-me-with-a-client-id
OAUTH_CLIENT_SECRET=replace-me-with-a-client-secret

# What you type into the browser login page to approve a new connector.
# Pick something memorable but not guessable; rotate freely.
OWNER_TOKEN=replace-me-with-an-owner-password

# Key used to sign access-token JWTs. Rotating it invalidates every issued
# token (forces re-auth from every Claude client).
# Generate with: openssl rand -hex 64
JWT_SIGNING_KEY=replace-me-with-a-long-random-string

# --- Server --------------------------------------------------------------

# Port the MCP server listens on (Fly maps this internally)
PORT=8080
